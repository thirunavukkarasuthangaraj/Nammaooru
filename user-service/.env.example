# User Service Environment Variables
# Copy this file to .env and fill in your values

# Database (user_db - separate from monolith's shop_management_db)
DB_URL=jdbc:postgresql://localhost:5432/user_db
DB_USERNAME=postgres
DB_PASSWORD=postgres

# JWT Secret (MUST be the same as monolith for shared token validation)
JWT_SECRET=your-jwt-secret-key-here

# SMTP / Email
MAIL_HOST=smtp.hostinger.com
MAIL_PORT=587
MAIL_USERNAME=noreplay@nammaoorudelivary.in
MAIL_PASSWORD=your-email-password

# MSG91 SMS Gateway
MSG91_AUTH_KEY=your-msg91-auth-key
MSG91_SENDER_ID=NAMMAO
MSG91_OTP_TEMPLATE_ID=your-otp-template-id
MSG91_FORGOT_PASSWORD_TEMPLATE_ID=your-forgot-password-template-id

# SMS toggle (set to false for development)
SMS_ENABLED=false

# Frontend URLs
FRONTEND_BASE_URL=https://nammaoorudelivary.in
FRONTEND_LOGIN_URL=https://nammaoorudelivary.in/auth/login
FRONTEND_RESET_PASSWORD_URL=https://nammaoorudelivary.in/auth/reset-password
