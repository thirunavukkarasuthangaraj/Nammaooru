# Nginx configuration for microservice routing
# Copy the relevant location blocks to your main nginx config
#
# Routing:
#   /api/auth/*  -> user-service (port 8081)
#   /api/users/* -> user-service (port 8081)
#   /internal/*  -> user-service (port 8081) [BLOCKED from external]
#   Everything else -> monolith backend (port 8080)

upstream user_service {
    server 127.0.0.1:8081;
}

upstream backend_service {
    server 127.0.0.1:8080;
}

server {
    listen 80;
    server_name your-domain.com;

    # Block internal endpoints from external access
    location /internal/ {
        deny all;
        return 403;
    }

    # Route auth endpoints to user-service
    location /api/auth/ {
        proxy_pass http://user_service;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # Route user endpoints to user-service
    location /api/users/ {
        proxy_pass http://user_service;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # All other API calls go to monolith
    location /api/ {
        proxy_pass http://backend_service;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # Static files, frontend, etc. (adjust as needed)
    location / {
        root /var/www/html;
        try_files $uri $uri/ /index.html;
    }
}
